generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  ACTIVE
  BLOCKED
  ARCHIVED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAYMENT_CONFIRMED
  PROCESSING
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ReturnStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  PICKUP_SCHEDULED
  IN_TRANSIT
  PRODUCT_RECEIVED
  INSPECTING
  REPLACEMENT_APPROVED
  REPLACEMENT_SENT
  REFUND_APPROVED
  REFUND_PROCESSING
  REFUNDED
  STORE_CREDIT_ISSUED
  CLOSED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_CUSTOMER
  WAITING_FOR_INTERNAL_TEAM
  RESOLVED
  CLOSED
}

enum DiscountType {
  PERCENT
  FIXED
  FREE_DELIVERY
  PRODUCT
  CATEGORY
  BRAND
  FIRST_ORDER
  CUSTOMER
  PAYMENT_METHOD
  BOGO
  TIERED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
  SUSPICIOUS
}

enum RefundStatus {
  REQUESTED
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model User {
  id                  String                   @id @default(cuid())
  name                String?
  email               String                   @unique
  phone               String?
  passwordHash        String?
  forcePasswordChange Boolean                  @default(false)
  status              UserStatus               @default(ACTIVE)
  emailVerified       DateTime?
  image               String?
  accounts            Account[]
  sessions            Session[]
  roles               UserRole[]
  profile             CustomerProfile?
  addresses           Address[]
  carts               Cart[]
  wishlist            Wishlist?
  orders              Order[]
  reviews             Review[]
  tickets             SupportTicket[]
  assignedTickets     SupportTicket[]          @relation("AssignedTickets")
  supportMessages     SupportMessage[]
  supportAttachments  SupportAttachment[]
  notifications       Notification[]
  couponEligibilities CouponCustomer[]
  reviewReplies       ReviewReply[]
  returnHistory       ReturnStatusHistory[]
  refundsCreated      Refund[]                 @relation("RefundCreatedBy")
  supportNotes        SupportInternalNote[]
  devEmails           DevelopmentEmailLog[]
  auditLogs           AuditLog[]
  files               FileAsset[]
  permissionOverrides UserPermissionOverride[]
  staffNote           String?
  lockedUntil         DateTime?
  failedLoginCount    Int                      @default(0)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([status, updatedAt])
  @@index([phone])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CustomerProfile {
  id            String  @id @default(cuid())
  userId        String  @unique
  gender        String?
  childAgeGroup String?
  rewardPoints  Int     @default(0)
  communication Json?
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id            String                   @id @default(cuid())
  key           String                   @unique
  description   String?
  roles         RolePermission[]
  userOverrides UserPermissionOverride[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model UserPermissionOverride {
  userId       String
  permissionId String
  effect       String     @default("ALLOW")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@index([permissionId])
}

model Address {
  id         String   @id @default(cuid())
  userId     String?
  label      String   @default("Home")
  name       String
  phone      String
  divisionId String?
  districtId String?
  areaId     String?
  division   String
  district   String
  area       String
  postalCode String?
  line1      String
  landmark   String?
  isDefault  Boolean  @default(false)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  orders     Order[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Category {
  id                  String            @id @default(cuid())
  parentId            String?
  name                String
  nameBn              String?
  slug                String            @unique
  description         String?
  descriptionBn       String?
  image               String?
  icon                String?
  sortOrder           Int               @default(0)
  active              Boolean           @default(true)
  featured            Boolean           @default(false)
  seoTitle            String?
  seoDescription      String?
  archivedAt          DateTime?
  parent              Category?         @relation("CategoryTree", fields: [parentId], references: [id])
  children            Category[]        @relation("CategoryTree")
  products            ProductCategory[]
  couponEligibilities CouponCategory[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model Brand {
  id                  String        @id @default(cuid())
  name                String
  slug                String        @unique
  logo                String?
  description         String?
  descriptionBn       String?
  website             String?
  country             String?
  active              Boolean       @default(true)
  featured            Boolean       @default(false)
  seoTitle            String?
  seoDescription      String?
  archivedAt          DateTime?
  products            Product[]
  couponEligibilities CouponBrand[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Product {
  id                  String              @id @default(cuid())
  name                String
  nameBn              String?
  slug                String              @unique
  sku                 String              @unique
  barcode             String?
  shortDescription    String
  shortDescriptionBn  String?
  fullDescription     String
  fullDescriptionBn   String?
  status              ProductStatus       @default(DRAFT)
  brandId             String?
  productType         String?
  tags                String?
  ageGroup            String?
  gender              String?
  material            String?
  weight              Float?
  length              Float?
  width               Float?
  height              Float?
  dimensions          String?
  deliveryClass       String?
  costPrice           Decimal?
  regularPrice        Decimal
  salePrice           Decimal?
  tax                 Decimal?
  taxable             Boolean             @default(false)
  trackStock          Boolean             @default(true)
  stock               Int                 @default(0)
  reservedStock       Int                 @default(0)
  lowStockThreshold   Int                 @default(5)
  minQuantity         Int                 @default(1)
  maxQuantity         Int?
  allowBackorder      Boolean             @default(false)
  stockStatus         String              @default("IN_STOCK")
  safetyInfo          String?
  careInstructions    String?
  specifications      Json?
  warranty            String?
  returnEligible      Boolean             @default(true)
  featured            Boolean             @default(false)
  newArrival          Boolean             @default(false)
  bestSeller          Boolean             @default(false)
  flashSale           Boolean             @default(false)
  preOrder            Boolean             @default(false)
  active              Boolean             @default(true)
  publishedAt         DateTime?
  saleStartsAt        DateTime?
  saleEndsAt          DateTime?
  seoTitle            String?
  seoDescription      String?
  searchKeywords      String?
  canonicalUrl        String?
  socialImage         String?
  archivedAt          DateTime?
  brand               Brand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  categories          ProductCategory[]
  variants            ProductVariant[]
  images              ProductImage[]
  inventory           Inventory?
  cartItems           CartItem[]
  wishlistItems       WishlistItem[]
  orderItems          OrderItem[]
  reviews             Review[]
  couponEligibilities CouponProduct[]
  recentlyViewed      RecentlyViewed[]
  stockNotifications  StockNotification[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([status, featured])
  @@index([regularPrice])
}

model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId, productId])
}

model ProductVariant {
  id                 String              @id @default(cuid())
  productId          String
  name               String?
  sku                String              @unique
  barcode            String?
  size               String?
  colour             String?
  material           String?
  style              String?
  priceOverride      Decimal?
  salePriceOverride  Decimal?
  costPriceOverride  Decimal?
  stock              Int                 @default(0)
  reservedStock      Int                 @default(0)
  lowStockThreshold  Int                 @default(5)
  weightOverride     Float?
  image              String?
  active             Boolean             @default(true)
  sortOrder          Int                 @default(0)
  status             ProductStatus       @default(PUBLISHED)
  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryMovements InventoryMovement[]
  orderItems         OrderItem[]
}

model ProductImage {
  id         String  @id @default(cuid())
  productId  String
  url        String
  alt        String
  sortOrder  Int     @default(0)
  variantKey String?
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Inventory {
  id            String              @id @default(cuid())
  productId     String              @unique
  available     Int                 @default(0)
  reserved      Int                 @default(0)
  sold          Int                 @default(0)
  returned      Int                 @default(0)
  damaged       Int                 @default(0)
  incoming      Int                 @default(0)
  warehouseCode String              @default("MAIN")
  product       Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements     InventoryMovement[]
}

model InventoryMovement {
  id               String          @id @default(cuid())
  inventoryId      String
  variantId        String?
  movementType     String          @default("CORRECTION")
  previousQuantity Int
  newQuantity      Int
  difference       Int
  reservedBefore   Int             @default(0)
  reservedAfter    Int             @default(0)
  reason           String
  reference        String?
  idempotencyKey   String?         @unique
  adminUserId      String?
  notes            String?
  inventory        Inventory       @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  variant          ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())

  @@index([movementType, createdAt])
  @@index([reference])
}

model Cart {
  id         String     @id @default(cuid())
  userId     String?
  guestToken String?
  couponCode String?
  user       User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      CartItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([guestToken])
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId, variantId])
}

model Wishlist {
  id     String         @id @default(cuid())
  userId String         @unique
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  WishlistItem[]
}

model WishlistItem {
  wishlistId String
  productId  String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([wishlistId, productId])
}

model Order {
  id                      String               @id @default(cuid())
  number                  String               @unique
  userId                  String?
  addressId               String?
  email                   String?
  phone                   String?
  subtotal                Decimal
  discount                Decimal              @default(0)
  deliveryFee             Decimal
  total                   Decimal
  status                  OrderStatus          @default(PENDING)
  paymentStatus           PaymentStatus        @default(PENDING)
  deliveryMethod          String
  deliveryZoneId          String?
  deliveryZoneName        String?
  deliveryRuleId          String?
  deliveryEstimateMinDays Int?
  deliveryEstimateMaxDays Int?
  codAvailableSnapshot    Boolean?
  paymentMethod           String
  courierProvider         String?
  courierOrderId          String?
  trackingId              String?
  deliveryNote            String?
  internalNotes           String?
  shippedAt               DateTime?
  deliveredAt             DateTime?
  couponCode              String?
  idempotencyKey          String?              @unique
  user                    User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  address                 Address?             @relation(fields: [addressId], references: [id], onDelete: SetNull)
  items                   OrderItem[]
  statusHistory           OrderStatusHistory[]
  payments                Payment[]
  returns                 ReturnRequest[]
  refunds                 Refund[]
  shipments               Shipment[]
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([userId, createdAt])
  @@index([courierProvider, courierOrderId])
  @@index([trackingId])
}

model DeliveryZone {
  id                    String             @id @default(cuid())
  name                  String
  nameBn                String?
  slug                  String             @unique
  description           String?
  descriptionBn         String?
  active                Boolean            @default(true)
  sortOrder             Int                @default(0)
  deliveryFee           Decimal
  freeDeliveryThreshold Decimal?
  minDeliveryDays       Int
  maxDeliveryDays       Int
  codAvailable          Boolean            @default(true)
  expressAvailable      Boolean            @default(false)
  expressFee            Decimal?
  fallback              Boolean            @default(false)
  pickup                Boolean            @default(false)
  metadata              Json?
  archivedAt            DateTime?
  rules                 DeliveryZoneRule[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([active, archivedAt])
  @@index([sortOrder])
}

model DeliveryZoneRule {
  id         String       @id @default(cuid())
  zoneId     String
  divisionId String?
  districtId String?
  areaId     String?
  priority   Int          @default(0)
  remoteOnly Boolean?
  zone       DeliveryZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([divisionId])
  @@index([districtId])
  @@index([areaId])
  @@index([priority])
  @@index([zoneId])
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  productId   String
  variantId   String?
  name        String
  sku         String
  quantity    Int
  unitPrice   Decimal
  discount    Decimal         @default(0)
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  returnItems ReturnItem[]
  review      Review?
}

model OrderStatusHistory {
  id         String       @id @default(cuid())
  orderId    String
  fromStatus OrderStatus?
  toStatus   OrderStatus
  note       String?
  actorId    String?
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
}

model Payment {
  id               String               @id @default(cuid())
  orderId          String
  provider         String
  status           PaymentStatus
  amount           Decimal
  reference        String?
  sessionKey       String?
  currency         String               @default("BDT")
  validationStatus String?
  callbackAt       DateTime?
  ipnAt            DateTime?
  failureReason    String?
  order            Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transactions     PaymentTransaction[]
  createdAt        DateTime             @default(now())

  @@index([orderId, status])
  @@index([reference])
}

model PaymentTransaction {
  id        String   @id @default(cuid())
  paymentId String
  type      String
  payload   Json?
  verified  Boolean  @default(false)
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model FileAsset {
  id                  String    @id @default(cuid())
  storageProvider     String
  storageKey          String    @unique
  publicUrl           String?
  originalFileName    String
  safeFileName        String
  mimeType            String
  size                Int
  purpose             String
  ownerUserId         String?
  relatedResourceType String?
  relatedResourceId   String?
  visibility          String    @default("CUSTOMER_OWNED")
  owner               User?     @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdAt           DateTime  @default(now())
  deletedAt           DateTime?

  @@index([ownerUserId, createdAt])
  @@index([relatedResourceType, relatedResourceId])
}

model Shipment {
  id                   String          @id @default(cuid())
  orderId              String
  provider             String
  externalShipmentId   String?
  consignmentId        String?
  trackingCode         String?
  status               String          @default("created")
  trackingUrl          String?
  providerCharge       Decimal?
  codAmount            Decimal         @default(0)
  recipientName        String
  recipientPhone       String
  address              String
  rawProviderReference Json?
  idempotencyKey       String          @unique
  lastSyncedAt         DateTime?
  cancelledAt          DateTime?
  order                Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events               ShipmentEvent[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@unique([orderId, provider])
  @@index([orderId, createdAt])
  @@index([provider, externalShipmentId])
}

model ShipmentEvent {
  id              String   @id @default(cuid())
  shipmentId      String
  providerEventId String?
  status          String
  description     String?
  payload         Json?
  shipment        Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@unique([shipmentId, providerEventId])
  @@index([shipmentId, createdAt])
}

model CourierWebhookEvent {
  id              String   @id @default(cuid())
  provider        String
  providerEventId String
  payload         Json?
  processedAt     DateTime @default(now())

  @@unique([provider, providerEventId])
}

model Coupon {
  id                      String           @id @default(cuid())
  code                    String           @unique
  normalizedCode          String           @unique
  name                    String?
  description             String?
  type                    DiscountType
  value                   Decimal          @default(0)
  percentageValue         Decimal?
  fixedValue              Decimal?
  startsAt                DateTime?
  expiresAt               DateTime?
  usageLimit              Int?
  perCustomerLimit        Int?
  minimumSpend            Decimal?
  minimumEligibleSubtotal Decimal?
  maximumDiscount         Decimal?
  active                  Boolean          @default(true)
  archivedAt              DateTime?
  excludedSaleProducts    Boolean          @default(false)
  stackable               Boolean          @default(false)
  firstOrderOnly          Boolean          @default(false)
  allowedPaymentMethods   String[]         @default([])
  products                CouponProduct[]
  categories              CouponCategory[]
  brands                  CouponBrand[]
  customers               CouponCustomer[]
  usages                  CouponUsage[]
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @default(now()) @updatedAt

  @@index([active, archivedAt])
  @@index([type])
  @@index([startsAt, expiresAt])
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  userId    String?
  orderId   String?
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([couponId, orderId])
  @@index([userId, createdAt])
}

model CouponProduct {
  couponId  String
  productId String
  coupon    Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([couponId, productId])
}

model CouponCategory {
  couponId   String
  categoryId String
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([couponId, categoryId])
}

model CouponBrand {
  couponId String
  brandId  String
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  brand    Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@id([couponId, brandId])
}

model CouponCustomer {
  couponId String
  userId   String
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([couponId, userId])
}

model Promotion {
  id       String       @id @default(cuid())
  name     String
  type     DiscountType
  rules    Json
  startsAt DateTime?
  endsAt   DateTime?
  active   Boolean      @default(true)
}

model Review {
  id               String        @id @default(cuid())
  productId        String
  userId           String
  orderItemId      String?       @unique
  rating           Int
  title            String?
  text             String
  verifiedPurchase Boolean       @default(false)
  status           ReviewStatus  @default(PENDING)
  reply            String?
  featured         Boolean       @default(false)
  suspicious       Boolean       @default(false)
  hiddenAt         DateTime?
  moderatedAt      DateTime?
  moderatedById    String?
  deletedAt        DateTime?
  product          Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItem        OrderItem?    @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  replies          ReviewReply[]
  images           ReviewImage[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([productId, userId])
  @@index([status, featured])
  @@index([rating])
}

model ReviewReply {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String?
  body      String
  public    Boolean  @default(true)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReviewImage {
  id       String @id @default(cuid())
  reviewId String
  url      String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model ReturnRequest {
  id                String                @id @default(cuid())
  number            String                @unique @default(cuid())
  orderId           String
  userId            String?
  status            ReturnStatus          @default(REQUESTED)
  reason            String
  description       String?
  resolution        String?
  notes             String?
  adminNote         String?
  inspectedAt       DateTime?
  inspectionResult  String?
  replacementSentAt DateTime?
  order             Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items             ReturnItem[]
  history           ReturnStatusHistory[]
  evidence          ReturnEvidence[]
  refunds           Refund[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model ReturnItem {
  id                    String        @id @default(cuid())
  returnId              String
  orderItemId           String
  quantity              Int
  resellableQty         Int           @default(0)
  damagedQty            Int           @default(0)
  replacementDispatched Boolean       @default(false)
  returnRequest         ReturnRequest @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItem             OrderItem     @relation(fields: [orderItemId], references: [id])

  @@unique([returnId, orderItemId])
}

model ReturnEvidence {
  id        String        @id @default(cuid())
  returnId  String
  url       String
  fileName  String?
  mimeType  String?
  size      Int?
  request   ReturnRequest @relation(fields: [returnId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
}

model ReturnStatusHistory {
  id               String        @id @default(cuid())
  returnId         String
  fromStatus       ReturnStatus?
  toStatus         ReturnStatus
  actorId          String?
  publicNote       String?
  privateAdminNote String?
  request          ReturnRequest @relation(fields: [returnId], references: [id], onDelete: Cascade)
  actor            User?         @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())

  @@index([returnId, createdAt])
}

model Refund {
  id                    String         @id @default(cuid())
  number                String         @unique @default(cuid())
  orderId               String
  returnRequestId       String?
  amount                Decimal
  deliveryFeeAmount     Decimal        @default(0)
  method                String
  status                RefundStatus   @default(REQUESTED)
  reason                String?
  externalTransactionId String?
  adminNote             String?
  idempotencyKey        String?        @unique
  createdById           String?
  processedAt           DateTime?
  order                 Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  returnRequest         ReturnRequest? @relation(fields: [returnRequestId], references: [id], onDelete: SetNull)
  createdBy             User?          @relation("RefundCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @default(now()) @updatedAt

  @@index([status, createdAt])
  @@index([orderId])
}

model SupportTicket {
  id            String                @id @default(cuid())
  number        String                @unique @default(cuid())
  userId        String?
  assignedToId  String?
  category      String
  priority      String                @default("NORMAL")
  subject       String
  status        TicketStatus          @default(OPEN)
  user          User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  assignedTo    User?                 @relation("AssignedTickets", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages      SupportMessage[]
  attachments   SupportAttachment[]
  internalNotes SupportInternalNote[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([status, createdAt])
  @@index([assignedToId])
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  senderId  String?
  body      String
  public    Boolean       @default(true)
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    User?         @relation(fields: [senderId], references: [id], onDelete: SetNull)
  createdAt DateTime      @default(now())
}

model SupportAttachment {
  id         String        @id @default(cuid())
  ticketId   String
  messageId  String?
  uploaderId String?
  url        String
  fileName   String
  mimeType   String
  size       Int
  deletedAt  DateTime?
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploader   User?         @relation(fields: [uploaderId], references: [id], onDelete: SetNull)
  createdAt  DateTime      @default(now())

  @@index([ticketId, createdAt])
}

model SupportInternalNote {
  id        String        @id @default(cuid())
  ticketId  String
  authorId  String?
  body      String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime      @default(now())
}

model Notification {
  id           String    @id @default(cuid())
  userId       String?
  type         String
  title        String
  body         String
  resourceType String?
  resourceId   String?
  href         String?
  readAt       DateTime?
  channel      String    @default("IN_APP")
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@index([userId, readAt, createdAt])
}

model DevelopmentEmailLog {
  id          String   @id @default(cuid())
  recipient   String
  subject     String
  template    String
  relatedType String?
  relatedId   String?
  preview     String
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

model BlogCategory {
  id    String     @id @default(cuid())
  name  String
  slug  String     @unique
  posts BlogPost[]
}

model BlogTag {
  id    String     @id @default(cuid())
  name  String
  slug  String     @unique
  posts BlogPost[] @relation("BlogPostTags")
}

model BlogPost {
  id             String        @id @default(cuid())
  title          String
  titleBn        String?
  slug           String        @unique
  excerpt        String
  excerptBn      String?
  content        String
  contentBn      String?
  featuredImage  String?
  author         String
  categoryId     String?
  readingTime    Int
  draft          Boolean       @default(true)
  publishedAt    DateTime?
  seoTitle       String?
  seoDescription String?
  category       BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags           BlogTag[]     @relation("BlogPostTags")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Banner {
  id         String  @id @default(cuid())
  title      String
  titleBn    String?
  subtitle   String?
  subtitleBn String?
  image      String?
  href       String?
  placement  String
  active     Boolean @default(true)
  sortOrder  Int     @default(0)
}

model PageContent {
  id             String   @id @default(cuid())
  key            String   @unique
  title          String
  titleBn        String?
  content        Json
  contentBn      Json?
  seoTitle       String?
  seoDescription String?
  updatedAt      DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
}

model LegalPolicyReview {
  id            String    @id @default(cuid())
  policy        String    @unique
  version       String?
  effectiveDate DateTime?
  reviewedBy    String?
  reviewDate    DateTime?
  status        String    @default("REQUIRES_REVIEW")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entity, entityId, createdAt])
  @@index([action, createdAt])
}

model RecentlyViewed {
  id        String   @id @default(cuid())
  userId    String?
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model StockNotification {
  id         String    @id @default(cuid())
  productId  String
  email      String?
  phone      String?
  notifiedAt DateTime?
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
}
